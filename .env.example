# =============================================================================
# Joplin API — Environment Variables
# =============================================================================
# Used by Container A (joplin-core) and Container B (joplin-mcp).
# Some variables are only needed for one container — see notes below.

# Joplin Server sync target URL (Container A only)
JOPLIN_SERVER_URL=https://joplin.example.com/

# Joplin Server credentials (Container A only)
JOPLIN_USERNAME=your-email@example.com
JOPLIN_PASSWORD=your-password

# Joplin Data API port (Container A only, default: 41184)
JOPLIN_DATA_API_PORT=41184

# Joplin API token — required for both containers
# Run "joplin config api.token" on an authenticated Joplin CLI to get this
JOPLIN_API_TOKEN=your-api-token

# URL of the joplin-core Data API (Container B only)
# Container B uses this to reach Container A on the internal Docker network
JOPLIN_CORE_URL=http://joplin-core:41184

# Log level: debug, info, warn, error, or silent (default: info)
LOG_LEVEL=info

# Sync interval in seconds (Container A only, default: 300)
SYNC_INTERVAL_SECONDS=300

# MCP HTTP server port (Container B only, default: 3000)
MCP_PORT=3000
